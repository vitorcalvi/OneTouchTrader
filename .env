# CloneTrader — environment configuration
# Frontend VITE_ variables are exposed to the client; server-side secrets MUST NOT use VITE_ prefix
# File organized with a Mobile section first, then other sections for clarity

# =============================================================================
# MOBILE - UI configuration for /mobile trading interface
# (Use comma-separated lists where applicable: e.g. STOP,MARKET,LIMIT)
# =============================================================================
VITE_MOBILE_DEFAULT_TICKERS=INTC,IREN
VITE_MOBILE_DEFAULT_PRESETS=10K,20K,30K,50K
VITE_MOBILE_DEFAULT_PRESET=20K


VITE_MOBILE_WIDTH=390
VITE_MOBILE_HEIGHT=844
VITE_MOBILE_MARGIN=12
VITE_MOBILE_PRICE_STEP_LARGE=1.00
VITE_MOBILE_PRICE_STEP_MID=0.1
VITE_MOBILE_PRICE_STEP_SMALL=0.01

# Order display ordering for mobile/global UI (comma-separated)
VITE_ORDER_TYPE=STOP,MARKET,LIMIT
# Mobile default tier order: first is the default when loading mobile UI
VITE_MOBILE_DEFAULT_TIER=S
VITE_MOBILE_DEFAULT_OSL=true

# =============================================================================
# OTHER SECTIONS
# (Server-side secrets, trading defaults, order settings, risk, fees, etc.)
# =============================================================================
# ALPACA API KEYS (server-side only)
ALPACA_PAPER_KEY=PKPJZCCQAVQJEMSOL5AEAH3F2F
ALPACA_PAPER_SECRET=DCsJraBgmEb7RgH1ePqygQVys6ZtZ3cqw5svU3zF4aWa
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=
VITE_ALPACA_IS_PAPER=true          # Use paper trading (true) or live (false)

# DATA PROVIDER
FINNHUB_API_KEY=d0kbqd1r01qn937js8jgd0kbqd1r01qn937js8k0  # Finnhub API for quotes/news

# TRADING — entry defaults
VITE_DEFAULT_SYMBOL=IREN
VITE_DEFAULT_QTY=100

# BRACKET ORDER defaults - used in mobile price action SL/TP toggles
VITE_AUTO_TAKE_PROFIT_PCT=2
VITE_AUTO_STOP_LOSS_PCT=1.5
VITE_BE_STOP_OFFSET=0.1
VITE_SL_STOP_OFFSET=1.5
VITE_TRAILING_STOP_DEFAULT_PCT=1.5
VITE_TRAILING_STOP_MIN_PCT=0.8

# LAYERED TRAILING STOPS - used by L&F (Live & Forget) preset
# L2 chases SL toward BE at 0.5%/tick; L3 trails runner from HWM at 1.5%.
# L3 < 1.0% gets stopped out by intraday noise on most equities (IREN/PLTR).
VITE_LAYER1_ENABLED=true
VITE_LAYER2_ENABLED=true
VITE_LAYER3_ENABLED=true
VITE_LAYER2_TRAIL_PCT=0.5
VITE_LAYER3_TRAIL_PCT=1.5

# LADDER PRESET - used by mobile ladder preset button
VITE_LADDER_PRICE_STEP=0.10
VITE_LADDER_ORDER_COUNT=3

# ORDER SETTINGS - used for all order submissions
VITE_DEFAULT_TIME_IN_FORCE=ioc
VITE_EXTENDED_HOURS=false
VITE_AGGRESSIVE_MODE=false
VITE_POLLING_INTERVAL=3
VITE_STOP_SLIPPAGE_PCT=0.05

# RISK LIMITS - used for position size validation
VITE_MAX_POSITION_SIZE_PERCENT=30

# FEES - used for P&L calculations and break-even analysis
VITE_ALPACA_STOCKS_FEE=0.0001194
VITE_ALPACA_CRYPTO_TAKER_FEE=0.003
VITE_ALPACA_CRYPTO_MAKER_FEE=-0.002

